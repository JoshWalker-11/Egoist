{
  "name": "egoist-soccer-training-tracker",
  "version": "1.0.0",
  "description": "Egoist Soccer Training Tracker (E.S.T) - Football Training Management Desktop App",
  "main": "src/main.js",
  "homepage": "./",
  "author": "JoshWalker-11",
  "license": "MIT",
  "scripts": {
    "start": "concurrently \"npm run react-start\" \"wait-on http://localhost:3000 && electron .\"",
    "react-start": "react-scripts start",
    "react-build": "react-scripts build",
    "react-test": "react-scripts test",
    "react-eject": "react-scripts eject",
    "electron-start": "electron .",
    "build-win": "npm run react-build && electron-builder --win",
    "build-all": "npm run react-build && electron-builder -mwl"
  },
  "dependencies": {
    "chart.js": "^3.9.1",
    "lucide-react": "^0.263.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-chartjs-2": "^4.3.1",
    "electron-is-dev": "^2.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.0.1",
    "electron": "^24.0.0",
    "electron-builder": "^24.0.0",
    "react-scripts": "5.0.1",
    "tailwindcss": "^3.3.0",
    "wait-on": "^7.0.1"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "build": {
    "appId": "com.egoist.soccer.trainer",
    "productName": "Egoist Soccer Training Tracker",
    "files": [
      "build/**/*",
      "src/main.js",
      "src/preload.js",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
